APP_NAME="Konji Shop"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.pl

APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL
APP_MAINTENANCE_DRIVER=cache

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=your-rds-endpoint.eu-central-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=konji_shop
DB_USERNAME=konji_shop
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=.example.pl

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
# Use redis when running the Redis container from docker-compose.prod.yml.
# Use your ElastiCache endpoint if you move Redis to AWS later.
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=shop@example.pl
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=konji-shop-production
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PAYMENT_DEFAULT_PROVIDER=paynow

PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=
PRZELEWY24_CRC=
PRZELEWY24_SANDBOX=true

PAYNOW_API_KEY=
PAYNOW_SIGNATURE_KEY=
PAYNOW_SANDBOX=false

POLKURIER_BASE_URL=https://api.polkurier.pl
POLKURIER_LOGIN=
POLKURIER_TOKEN=
POLKURIER_SENDER_COMPANY=
POLKURIER_SENDER_PERSON=
POLKURIER_SENDER_STREET=
POLKURIER_SENDER_HOUSE_NUMBER=
POLKURIER_SENDER_FLAT_NUMBER=
POLKURIER_SENDER_POSTCODE=
POLKURIER_SENDER_CITY=
POLKURIER_SENDER_EMAIL=
POLKURIER_SENDER_PHONE=
POLKURIER_SENDER_COUNTRY=PL
POLKURIER_SENDER_POINT_ID=
POLKURIER_LABEL_DISK=s3
POLKURIER_LABEL_PATH=polkurier/labels
POLKURIER_PROTOCOL_DISK=s3
POLKURIER_PROTOCOL_PATH=polkurier/protocols
POLKURIER_AVAILABLE_CARRIERS_CACHE_TTL=43200
POLKURIER_AVAILABLE_CARRIERS_GUARDS_ENABLED=true
POLKURIER_AVAILABLE_CARRIERS_FAIL_WHEN_CACHE_EMPTY=false
POLKURIER_AVAILABLE_CARRIERS_BLOCK_REQUIRED_ADDITIONAL_FIELDS=true
POLKURIER_VALUATION_ENABLED=true
POLKURIER_FALLBACK_INPOST_PARCEL_LOCKER_AMOUNT=1500
POLKURIER_FALLBACK_INPOST_COURIER_AMOUNT=2200
POLKURIER_FALLBACK_UPS_COURIER_AMOUNT=2200
POLKURIER_FALLBACK_DPD_COURIER_AMOUNT=2200

LEGAL_TERMS_VERSION=2026-05-30
LEGAL_PRIVACY_VERSION=2026-05-30
LEGAL_RETURNS_VERSION=2026-05-30

SHOP_NAME="Konji Shop"
SHOP_COMPANY_NAME=
SHOP_REPRESENTATIVE=
SHOP_STREET=
SHOP_POSTCODE=
SHOP_CITY=
SHOP_COUNTRY=Poland
SHOP_EMAIL=shop@example.pl
SHOP_PHONE=
SHOP_TAX_ID=
SHOP_REGISTRY_NUMBER=
SHOP_RETURN_ADDRESS=
SHOP_RETURNS_EMAIL=returns@example.pl

# Storefront cache settings. Keep Redis enabled in production.
STOREFRONT_CACHE_ENABLED=true
STOREFRONT_CACHE_STORE=redis
STOREFRONT_PRODUCT_PAGE_CACHE_TTL=86400
STOREFRONT_CATEGORY_SIDEBAR_CACHE_TTL=86400
