APP_NAME=KonjiShop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=konji_shop
DB_USERNAME=konji
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================
# PAYMENT GATEWAYS CONFIGURATION
# =============================================

PAYMENT_DEFAULT_PROVIDER=paynow

# ---------------- Przelewy24 (pauza) ----------------
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=
PRZELEWY24_CRC=
PRZELEWY24_SANDBOX=true

# ---------------- Paynow (aktywna teraz) ----------------
PAYNOW_API_KEY=
PAYNOW_SIGNATURE_KEY=
PAYNOW_SANDBOX=true

# ---------------- Polkurier ----------------

POLKURIER_BASE_URL=https://api.polkurier.pl
POLKURIER_LOGIN=
POLKURIER_TOKEN=

POLKURIER_SENDER_COMPANY=
POLKURIER_SENDER_PERSON=
POLKURIER_SENDER_STREET=
POLKURIER_SENDER_HOUSE_NUMBER=
POLKURIER_SENDER_FLAT_NUMBER=
POLKURIER_SENDER_POSTCODE=
POLKURIER_SENDER_CITY=
POLKURIER_SENDER_EMAIL=
POLKURIER_SENDER_PHONE=
POLKURIER_SENDER_COUNTRY=PL
POLKURIER_SENDER_MACHINE_NAME=
